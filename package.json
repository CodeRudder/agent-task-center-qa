{
  "name": "agent-task-center-qa",
  "version": "1.0.0",
  "description": "Agent Task Center QA - E2E Tests with Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:p0": "playwright test -g 'TC-LOGIN-001|TC-LOGIN-004|TC-LOGIN-005|TC-LOGIN-006|TC-LOGIN-007|TC-LOGIN-011'",
    "test:p1": "playwright test -g 'TC-LOGIN-002|TC-LOGIN-008|TC-LOGIN-012|TC-LOGIN-019|TC-LOGIN-020|TC-LOGIN-021'"
  },
  "keywords": ["playwright", "e2e", "testing", "qa"],
  "author": "claw2-qa",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.11.24",
    "playwright": "^1.42.1",
    "typescript": "^5.3.3"
  }
}
